{
  "manifest_version": 3,
  "name": "DSAlytics Bulk Importer",
  "version": "1.0",
  "description": "One-click bulk import of your LeetCode history to DSAlytics.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DSAlytics Sync"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"]
    }
  ]
}
